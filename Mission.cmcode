	CustomStrings = {


		--Dialogue

		["Operator.Any.IntroDialogue"] = "Remember our plan. I'll give you a signal if I'm compromised ¥n So you better pay attention to your radios.",
		["Operator.Any.IntroDialogue2"] = "Why don't we just go guns blazing from the get-go? Beats me. ¥n These are the instructions we were given.",
		
		["Operator.Any.PickedThermite1"] = "So...do any of you know what this thermite is for? No? ¥n Is upper management pulling some sort of prank on us?",
		["Operator.Any.PickedThermite2"] = "It's strange that they sent a whole SWAT team. ¥n Local weirdos should be handled by the police.",
		["Operator.Any.PickedThermite3"] = "I would rather be anywhere else than in nowhere-Appalachia. ¥n Let's get this over with quickly.",
		["Operator.Any.PickedThermite4"] = "This mission is such a pointless waste of time. ¥n I thought being an FBI agent meant fighting criminals, not chasing ghosts...",
		
		["Operator.Any.MainRoomDialogue1"] = "A door with an electronic lock? Suppose I found my lead. ¥n I'm sure the old man holds a keycard.",
		["Operator.Any.MainRoomDialogue2"] = "That metal door certainly draws suspicion. ¥n I'm sure the old man holds a keycard.",
		
		["Operator.Any.EnteredLabDialogue1"] = "Deeper down the rabbit hole...",
		["Operator.Any.EnteredLabDialogue2"] = "What I have gotten myself into?",
		["Operator.Any.EnteredLabDialogue3"] = "I don't know what to expect anymore ¥n I've got to be careful...",
		
		["Operator.Any.InspectedGooDialogue1"] = "Some sort of...spasming meat? It smells rotten. ¥n Disgusting",
		["Operator.Any.InspectedGooDialogue2"] = "A viscous substance. It looks like muscles contracting...",
		
		["Operator.Any.AuthorizationDialogue"] = "It seems I need authorization from two other computers to open the vault.",
		
		["Operator.Any.ShedFound1"] = "That's a tough lock.",
		["Operator.Any.ShedFound2"] = "Why does this shed have such a tough lock?",
		
		["Operator.Any.ShedCleared"] = "A security center hidden in plain sight...",
		
		["Operator.Any.DisguiseFound"] = "This robe is torn, but I might be able to patch it up...",
		
		["Operator.Any.TakedownLimitDialogue"] = "They'll probably notice if all the priests are gone. ¥n I need to be careful.",
	
		["Operator.Any.EmptySearch1"] = "Incriminating evidence, but it isn't of any use right now.",
		["Operator.Any.EmptySearch2"] = "Useless reports...",
		["Operator.Any.EmptySearch3"] = "Nothing here.",
		
		["Operator.Any.ThermiteStartedDialogue"] = "DO YOU READ ME? ¥n I NEED REINFORCEMENTS *RIGHT NOW*",

		--Objectives

		["Objective.Mission1"] = "Pick up the Thermite Bag",
		["Objective.Mission2"] = "Look for anything suspicious",
		["Objective.Mission3"] = "Get through the Electric-Locked Door",
		["Objective.Mission4"] = "",
		["Objective.Mission5"] = "Open the Vault",
		["Objective.Mission6"] = "Gain Authorization",
		["Objective.Mission7"] = "Find a Vault Keycard",
		["Objective.Mission8"] = "...",
		["Objective.Mission9"] = "Place the Thermite",
		["Objective.Mission10"] = "Escape",
		["Objective.FindCloth"] = "Gather pieces of Cloth",
		["Objective.UnlockShed"] = "Unlock the Shed",
		["Objective.TakedownLimit"] = "Incapacitating a Priest will raise the Alarm",
		["Ui.Optional"] = "Optional",
		["Ui.TakedownLimit"] = "Takedown Limit",

		--Guard Names

		["Name.Occultist"] = "Occultist",
		["Name.Leader"] = "High Priest",
		["Name.Scientist"] = "Scientist",
		["Name.DemonSpawn"] = "Demon Spawn",


